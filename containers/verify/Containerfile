FROM cgr.dev/chainguard/wolfi-base:latest AS builder

RUN apk add --no-cache \
    go \
    nodejs \
    npm \
    jq \
    grep \
    coreutils \
    diffutils \
    sed \
    gawk

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go build -o /usr/local/bin/openspec ./cmd/openspec

# --- Runtime ---
FROM cgr.dev/chainguard/wolfi-base:latest

RUN apk add --no-cache \
    nodejs \
    npm \
    jq \
    grep \
    coreutils \
    diffutils \
    sed \
    gawk

# Install TypeScript openspec globally
RUN npm install -g @fission-ai/openspec 2>/dev/null || true

COPY --from=builder /usr/local/bin/openspec /usr/local/bin/openspec
COPY --from=builder /src/testdata /work/testdata
COPY --from=builder /src/openspec /work/openspec
COPY --from=builder /src/scripts /work/scripts

WORKDIR /work
ENV REPO_ROOT=/work
ENV GO_BIN=/usr/local/bin/openspec
ENV TS_BIN="npx @fission-ai/openspec"

# Default: run both audits
COPY containers/verify/entrypoint.sh /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
